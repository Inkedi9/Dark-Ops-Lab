# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# CORS — required. Set to your deployed dark-nexus URL (e.g. https://darknexus.vercel.app).
# The server refuses to start if this variable is missing or empty.
# Development: http://localhost:3000
ALLOWED_ORIGIN=

# Path to the server-side challenges config (never commit challenges.json)
CHALLENGES_CONFIG=challenges.json

# Server
PORT=8080
