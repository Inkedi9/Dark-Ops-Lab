# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# CORS — set to your deployed dark-nexus URL in production
ALLOWED_ORIGIN=http://localhost:3000

# Path to the server-side challenges config (never commit challenges.json)
CHALLENGES_CONFIG=challenges.json

# Server
PORT=8080
