{
  "name": "dark-ops-lab",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n nexus,api -c cyan,magenta \"npm run dev:nexus\" \"npm run dev:api\"",
    "dev:nexus": "npm --workspace=apps/dark-nexus run dev",
    "dev:api": "cd apps/dark-api && go run ./cmd/server",
    "build": "npm --workspace=apps/dark-nexus run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
